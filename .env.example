# Distribution metadata URL
REMOTE_DISTRO_URL=http://your-server:8080/distribution.json

# GitHub release/update settings
GITHUB_OWNER=your-github-owner
GITHUB_REPO=your-private-repo
GITHUB_PUBLIC_OWNER=your-github-owner
GITHUB_PUBLIC_REPO=your-public-repo
GH_TOKEN=your_github_token

# Azure app registration
AZURE_ID=your-azure-client-id

# Landing social media links
LAUNCHER_MEDIA_GITHUB_URL=https://github.com/your-org/your-repo
LAUNCHER_MEDIA_X_URL=https://x.com/your_account
LAUNCHER_MEDIA_INSTAGRAM_URL=https://instagram.com/your_account
LAUNCHER_MEDIA_YOUTUBE_URL=https://youtube.com/@your_channel
LAUNCHER_MEDIA_DISCORD_URL=https://discord.gg/your_invite
